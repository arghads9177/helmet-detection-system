# Training / batch-inference image. Swap the base for a CUDA image matching your
# training hardware, e.g. nvidia/cuda:12.1.0-runtime-ubuntu22.04 + a python install.
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 libglib2.0-0 && rm -rf /var/lib/apt/lists/*

COPY requirements.txt requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY ml/ ml/
COPY scripts/ scripts/
COPY configs/ configs/

ENV PYTHONPATH=/app
CMD ["python", "-m", "ml.training.train", "--config", "configs/training.yaml"]
